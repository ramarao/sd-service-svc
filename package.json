{
  "name": "sd-service-svc",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-provider on-site service platform (pickup \u2192 service \u2192 deliver) on Cloudflare Workers with WhatsApp Business API",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev -c apps/dhobi/wrangler.jsonc",
    "dev:dhobi": "wrangler dev -c apps/dhobi/wrangler.jsonc",
    "deploy": "wrangler deploy -c apps/dhobi/wrangler.jsonc",
    "deploy:dhobi": "wrangler deploy -c apps/dhobi/wrangler.jsonc",
    "db:local": "wrangler d1 execute sd-service-db --local -c apps/dhobi/wrangler.jsonc --file=./apps/dhobi/schema.sql",
    "db:remote": "wrangler d1 execute sd-service-db --remote -c apps/dhobi/wrangler.jsonc --file=./apps/dhobi/schema.sql",
    "seed:local": "wrangler d1 execute sd-service-db --local -c apps/dhobi/wrangler.jsonc --file=./apps/dhobi/seed.sql",
    "tail": "wrangler tail -c apps/dhobi/wrangler.jsonc",
    "dev:homeease": "wrangler dev -c apps/homeease/wrangler.jsonc --port 8788",
    "deploy:homeease": "wrangler deploy -c apps/homeease/wrangler.jsonc",
    "db:local:homeease": "wrangler d1 execute sd-homeease-db --local -c apps/homeease/wrangler.jsonc --file=./apps/homeease/schema.sql",
    "seed:local:homeease": "wrangler d1 execute sd-homeease-db --local -c apps/homeease/wrangler.jsonc --file=./apps/homeease/seed.sql",
    "setup:email": "node scripts/setup-email-routing.mjs"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jsqr": "^1.4.0",
    "postal-mime": "^2.7.5",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "wrangler": "^4.107.1"
  }
}